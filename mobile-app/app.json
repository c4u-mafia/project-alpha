{
  "expo": {
    "name": "Homelyn",
    "slug": "Homelyn",
    "version": "1.0.0",
    "scheme": "homelyn",
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true,
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0E7C7B"
        }
      ],
      "expo-status-bar",
      "expo-web-browser"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Homelyn"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.Homelyn"
    }
  }
}
